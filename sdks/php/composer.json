{
    "name": "{{ORG_SLUG}}/{{SDK_SLUG}}-sdk",
    "description": "{{SDK_NAME}} - PHP SDK",
    "version": "{{SDK_VERSION}}",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/{{GITHUB_ORG}}/{{SDK_SLUG}}-sdk",
    "keywords": [
        "sdk",
        "api",
        "{{SDK_SLUG}}"
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SdkTpl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SdkTpl\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
